    {
        "id": "eda5a39891466e40",
        "type": "ui_template",
        "z": "89dc755a187e8b2a",
        "group": "group_timeline_cat",
        "name": "行為時間紀錄",
        "order": 2,
        "width": "6",
        "height": "10",
        "format": "<style>\n.behavior-container {\npadding: 15px;\nbackground: #fafbfc;\nborder-radius: 12px;\nfont-family: 'Microsoft JhengHei';\nmax-height: 500px;\noverflow-y: auto;\n}\n\n/* 標題 */\n.behavior-title {\ndisplay: flex;\njustify-content: space-between;\nalign-items: center;\nfont-weight: 700;\nfont-size: 1.2em;\nmargin-bottom: 15px;\nborder-bottom: 2px solid #667eea;\npadding-bottom: 8px;\n}\n\n.behavior-subtitle {\nfont-size: 0.75em;\ncolor: #888;\n}\n\n/* 無資料 */\n.no-data {\ntext-align: center;\npadding: 40px;\n}\n\n.no-data-icon {\nfont-size: 3em;\nopacity: 0.5;\n}\n\n.no-data-text {\ncolor: #666;\nmargin-top: 10px;\n}\n\n.no-data-sub {\nfont-size: 0.85em;\ncolor: #aaa;\n}\n\n/* timeline */\n.timeline {\npadding-left: 30px;\n}\n\n/* item */\n.timeline-item {\nposition: relative;\npadding: 12px 0 12px 20px;\nborder-left: 3px solid #ddd;\nmargin-bottom: 12px;\nborder-radius: 6px;\ntransition: 0.2s;\n}\n\n.timeline-item:hover {\nbackground: #f1f3f5;\n}\n\n/* dot */\n.timeline-dot {\nposition: absolute;\nleft: -7px;\ntop: 18px;\nwidth: 14px;\nheight: 14px;\nborder-radius: 50%;\nbackground: #667eea;\n}\n\n/* 行為顏色 */\n.timeline-item.scratch { border-left-color: #ff6b6b; }\n.timeline-item.lick { border-left-color: #ffa726; }\n.timeline-item.walk { border-left-color: #4caf50; }\n.timeline-item.shake { border-left-color: #42a5f5; }\n\n.timeline-item.scratch .timeline-dot { background:#ff6b6b; }\n.timeline-item.lick .timeline-dot { background:#ffa726; }\n.timeline-item.walk .timeline-dot { background:#4caf50; }\n.timeline-item.shake .timeline-dot { background:#42a5f5; }\n\n/* 時間 */\n.timeline-time {\nfont-size: 0.85em;\ncolor: #666;\nmargin-bottom: 5px;\n}\n\n/* 行為 */\n.timeline-behavior {\nfont-size: 1.05em;\nfont-weight: 600;\ndisplay: flex;\nalign-items: center;\n}\n\n.timeline-behavior .emoji {\nmargin-right: 8px;\n}\n\n/* duration */\n.timeline-duration {\nfont-size: 0.8em;\ncolor: #888;\nmargin-top: 4px;\n}\n.timeline-item.scratch .timeline-duration,\n.timeline-item.groom .timeline-duration {\n    background: #fff3cd;\n    color: #856404;\n    border: 1px solid #ffeeba;\n}\n\n.no-data {\n    text-align: center;\n    padding: 60px 20px;\n    color: #95a5a6;\n}\n\n.no-data-icon {\n    font-size: 4em;\n    margin-bottom: 15px;\n    opacity: 0.5;\n}\n\n.no-data-text {\n    font-size: 1.1em;\n    color: #7f8c8d;\n}\n\n.behavior-container::-webkit-scrollbar {\n    width: 8px;\n}\n\n.behavior-container::-webkit-scrollbar-track {\n    background: #f1f3f5;\n    border-radius: 10px;\n}\n\n.behavior-container::-webkit-scrollbar-thumb {\n    background: #667eea;\n    border-radius: 10px;\n}\n\n.behavior-container::-webkit-scrollbar-thumb:hover {\n    background: #5568d3;\n}\n</style>\n\n<div class=\"behavior-container\">\n\n    <div class=\"behavior-title\">\n        <span>📋 行為時間軸</span>\n        <span class=\"behavior-subtitle\">最近 20 筆紀錄</span>\n    </div>\n\n    <!-- 無資料 -->\n    <div ng-if=\"!msg.payload || !msg.payload.behavior_log || msg.payload.behavior_log.length === 0\" class=\"no-data\">\n        <div class=\"no-data-icon\">📭</div>\n        <p class=\"no-data-text\">暫無行為記錄</p>\n        <p class=\"no-data-sub\">等待貓咪活動...</p>\n    </div>\n\n    <!-- timeline -->\n    <div ng-if=\"msg.payload && msg.payload.behavior_log && msg.payload.behavior_log.length > 0\" class=\"timeline\">\n\n        <div ng-repeat=\"item in msg.payload.behavior_log track by $index\" class=\"timeline-item\"\n            ng-class=\"item.behavior\">\n\n            <div class=\"timeline-dot\"></div>\n\n            <!-- 時間 -->\n            <div class=\"timeline-time\">\n                🕐 {{item.time || '--:--'}}\n            </div>\n\n            <!-- 行為 -->\n            <div class=\"timeline-behavior\">\n                <span class=\"emoji\">{{item.emoji || '🐾'}}</span>\n                <span class=\"text\">\n                    {{ item.behavior === 'scratch' ? '搔抓' :\n                       item.behavior === 'lick' ? '舔舐' :\n                       item.behavior === 'walk' ? '行走' :\n                       item.behavior === 'shake' ? '甩頭' : item.behavior }}\n                </span>\n            </div>\n\n            <!-- 持續時間 -->\n            <div class=\"timeline-duration\" ng-if=\"item.duration > 0\">\n                ⏱️ {{item.duration || 0}} 秒\n            </div>\n\n        </div>\n\n    </div>\n\n</div>",
