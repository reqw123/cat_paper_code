    {
        "id": "583503209c7f6b21",
        "type": "function",
        "z": "89dc755a187e8b2a",
        "name": "數據分發器",
        "func": "let data = msg.payload;\n\n// === 防呆 ===\nif (!data) return null;\n\n// === 修正 behavior_log（讓 UI 正常吃）===\nif (data.behavior_log) {\n    data.behavior_log = data.behavior_log.map(item => {\n        return {\n            behavior: item.behavior,   // 保持 lick / scratch / walk / shake\n            time: item.time,\n            duration: item.duration,\n            emoji: getEmoji(item.behavior)\n        };\n    });\n}\n\n// === 補 emoji（確保 UI 不炸）===\nif (data.current && !data.current.emoji) {\n    data.current.emoji = getEmoji(data.current.behavior);\n}\n\n// === UI 主輸出 ===\nlet ui_msg = {\n    payload: data\n};\n\n// === Gauge 專用 ===\nlet gauge_msg = {\n    payload: data.activity_score || 0\n};\n\n// === 輸出 ===\nreturn [\n    ui_msg,   // 即時狀態\n    ui_msg,   // timeline\n    ui_msg,   // stats\n    ui_msg,   // alerts\n    gauge_msg // gauge\n];\n\n\n// === emoji helper ===\nfunction getEmoji(behavior) {\n    switch (behavior) {\n        case \"scratch\": return \"🐾\";\n        case \"lick\": return \"🧼\";\n        case \"walk\": return \"🚶\";\n        case \"shake\": return \"🔄\";\n        default: return \"🐱\";\n    }\n}",
