    "name": "P2 部位時長統計",
    "order": 1,
    "width": "0",
    "height": "9",
    "format": "<style>\n.lk{font-family:'Microsoft JhengHei',sans-serif;padding:12px 14px;background:#0d1117;border-radius:14px;color:#fff}\n.lk-title{font-size:11px;font-weight:700;color:rgba(255,255,255,.45);margin-bottom:10px;padding-bottom:7px;border-bottom:1px solid rgba(255,255,255,.08);letter-spacing:.6px}\n.lk-best{display:flex;align-items:center;gap:10px;padding:8px 14px;background:rgba(249,168,37,.1);border:1px solid rgba(249,168,37,.3);border-radius:10px;margin-bottom:12px}\n.lk-best-lbl{font-size:11px;color:rgba(249,168,37,.75);font-weight:600}\n.lk-best-zone{font-size:22px;font-weight:900;color:#ffd54f;letter-spacing:-.5px}\n.lk-best-pct{font-size:13px;color:rgba(255,255,255,.5)}\n.lk-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-bottom:12px}\n.lk-card{border-radius:12px;padding:12px 10px;text-align:center;position:relative}\n.lk-card.body{background:rgba(249,168,37,.12);border:1px solid rgba(249,168,37,.3)}\n.lk-card.fl  {background:rgba(30,136,229,.12);border:1px solid rgba(30,136,229,.3)}\n.lk-card.fr  {background:rgba(30,136,229,.09);border:1px solid rgba(30,136,229,.22)}\n.lk-card.hl  {background:rgba(92,107,192,.12);border:1px solid rgba(92,107,192,.3)}\n.lk-card.hr  {background:rgba(92,107,192,.09);border:1px solid rgba(92,107,192,.22)}\n.lk-ico{font-size:20px;margin-bottom:3px}\n.lk-zone-name{font-size:10px;color:rgba(255,255,255,.4);margin-bottom:10px;font-weight:600;letter-spacing:.5px}\n.lk-count{font-size:32px;font-weight:900;color:#fff;line-height:1;margin-bottom:0}\n.lk-count-lbl{font-size:10px;color:rgba(255,255,255,.4);margin-bottom:10px;font-weight:600;letter-spacing:.4px}\n.lk-time{font-size:22px;font-weight:800;color:#ffe082;line-height:1;margin-bottom:2px}\n.lk-time-lbl{font-size:9px;color:rgba(255,255,255,.35);margin-bottom:8px;letter-spacing:.4px}\n.lk-bar{height:5px;background:rgba(255,255,255,.08);border-radius:99px;overflow:hidden;margin-bottom:6px}\n.lk-bar-fill{height:100%;border-radius:99px}\n.body .lk-bar-fill{background:#f9a825}\n.fl   .lk-bar-fill{background:#1e88e5}\n.fr   .lk-bar-fill{background:#42a5f5}\n.hl   .lk-bar-fill{background:#5c6bc0}\n.hr   .lk-bar-fill{background:#7986cb}\n.lk-sph{font-size:10px;color:rgba(255,255,255,.35)}\n.lk-detail-title{font-size:10px;color:rgba(255,255,255,.35);letter-spacing:.6px;margin-bottom:7px;font-weight:700}\n.lk-tbl{width:100%;border-collapse:collapse}\n.lk-tbl th{padding:6px 10px;font-size:10px;font-weight:700;color:rgba(255,255,255,.4);background:rgba(255,255,255,.05);text-align:right;border:1px solid rgba(255,255,255,.06)}\n.lk-tbl th:first-child{text-align:left}\n.lk-tbl td{padding:7px 10px;border:1px solid rgba(255,255,255,.05);text-align:right;vertical-align:middle}\n.lk-tbl td:first-child{text-align:left;color:rgba(255,255,255,.65);font-size:12px}\n.lk-tbl tr:nth-child(even) td{background:rgba(255,255,255,.02)}\n.td-hits{font-size:18px;font-weight:900;color:#fff}\n.td-time{font-size:17px;font-weight:800;color:#ffe082}\n.td-pct{font-size:14px;font-weight:700;color:#80cbc4}\n.td-avg{font-size:13px;font-weight:600;color:rgba(255,255,255,.55)}\n</style>\n\n<div class='lk' id='root'>\n  <div class='lk-title'>📊 部位時長統計（累計至當幀）</div>\n  <div class='lk-best' id='best-row' style='display:none'></div>\n  <div class='lk-grid' id='grid'></div>\n  <div class='lk-detail-title'>ZONE DETAIL</div>\n  <table class='lk-tbl'>\n    <thead>\n      <tr>\n        <th>部位</th><th>進入次數</th><th>舔舐時長 (s)</th><th>偏好佔比 (%)</th><th>每次平均 (s)</th>\n      </tr>\n    </thead>\n    <tbody id='tbody'></tbody>\n  </table>\n</div>\n\n<script>\n(function(scope){\n  var ZONE_LIST=[\n    {key:'BODY',label:'身體中心',ico:'🐈',cls:'body',span:3},\n    {key:'FL',  label:'前左腳',  ico:'🐾',cls:'fl',  span:3},\n    {key:'FR',  label:'前右腳',  ico:'🐾',cls:'fr',  span:2},\n    {key:'HL',  label:'後左腳',  ico:'🐾',cls:'hl',  span:2},\n    {key:'HR',  label:'後右腳',  ico:'🐾',cls:'hr',  span:2}\n  ];\n  var CN={BODY:'身體中心',FL:'前左腳',FR:'前右腳',HL:'後左腳',HR:'後右腳'};\n  function fmtSec(s){if(!s||isNaN(s))return'0s';s=parseFloat(s);var m=Math.floor(s/60),sec=parseFloat((s%60).toFixed(1));return m?m+'m '+sec+'s':sec+'s';}\n  function fmtPct(v){return(!isNaN(v)&&isFinite(v)&&v>=0)?parseFloat(v).toFixed(1):'—';}\n  function isNum(v){return!isNaN(v)&&isFinite(v)&&v>=0;}\n\n  function render(data){\n    var bz=data.best_zone;\n    var bestRow=document.getElementById('best-row');\n    if(bz&&bz!=='NO_TARGET'){\n      bestRow.style.display='';\n      bestRow.innerHTML='<span class=\"lk-best-lbl\">⭐ 最高偏好部位</span>'\n        +'<span class=\"lk-best-zone\">'+CN[bz]+'</span>'\n        +'<span class=\"lk-best-pct\">佔 '+fmtPct(data.best_pct)+'% 舔舐時間</span>';\n    }else{bestRow.style.display='none';}\n\n    var grid=document.getElementById('grid');\n    grid.innerHTML=ZONE_LIST.map(function(z){\n      var d=(data.zones&&data.zones[z.key])||{hits:0,time_sec:0,pref_pct:NaN,sec_per_hit:NaN};\n      var pct=isNum(d.pref_pct)?fmtPct(d.pref_pct)+'%':'N/A';\n      return '<div class=\"lk-card '+z.cls+'\" style=\"grid-column:span '+z.span+'\">'\n        +'<div class=\"lk-ico\">'+z.ico+'</div>'\n        +'<div class=\"lk-zone-name\">'+z.label+'</div>'\n        +'<div class=\"lk-count\">'+d.hits+'</div>'\n        +'<div class=\"lk-count-lbl\">進入次數</div>'\n        +'<div class=\"lk-bar\"><div class=\"lk-bar-fill\" style=\"width:'+fmtPct(d.pref_pct)+'%\"></div></div>'\n        +'<div class=\"lk-time\">'+fmtSec(d.time_sec)+'</div>'\n        +'<div class=\"lk-time-lbl\">舔舐時長</div>'\n        +'<div class=\"lk-sph\">偏好 '+pct+'</div>'\n        +'</div>';\n    }).join('');\n\n    var tbody=document.getElementById('tbody');\n    tbody.innerHTML=ZONE_LIST.map(function(z){\n      var d=(data.zones&&data.zones[z.key])||{hits:0,time_sec:0,pref_pct:NaN,sec_per_hit:NaN};\n      return '<tr>'\n        +'<td>'+z.ico+' '+z.label+'</td>'\n        +'<td class=\"td-hits\">'+d.hits+'</td>'\n        +'<td class=\"td-time\">'+fmtSec(d.time_sec)+'</td>'\n        +'<td class=\"td-pct\">'+(isNum(d.pref_pct)?fmtPct(d.pref_pct)+'%':'—')+'</td>'\n        +'<td class=\"td-avg\">'+(isNum(d.sec_per_hit)?fmtSec(d.sec_per_hit):'—')+'</td>'\n        +'</tr>';\n    }).join('');\n  }\n\n  scope.$watch('msg', function(msg){\n    if(msg&&msg.payload) render(msg.payload);\n  });\n})(scope);\n</script>",
