  {
    "id": "a3b34fe8204e2270",
    "type": "function",
    "z": "889faede23dd76c6",
    "name": "舔舐部位分析器",
    "func": "let d = msg.payload;\nif (!d) return [null, null, null];\n\n// Compute pref% and sec/hit from plugin slim payload (new field names)\nlet times = {\n    BODY: parseFloat(d.body_time || 0),\n    FL:   parseFloat(d.fl_time   || 0),\n    FR:   parseFloat(d.fr_time   || 0),\n    HL:   parseFloat(d.hl_time   || 0),\n    HR:   parseFloat(d.hr_time   || 0)\n};\nlet hits = {\n    BODY: parseInt(d.body_hits || 0),\n    FL:   parseInt(d.fl_hits   || 0),\n    FR:   parseInt(d.fr_hits   || 0),\n    HL:   parseInt(d.hl_hits   || 0),\n    HR:   parseInt(d.hr_hits   || 0)\n};\nlet totalTime = Object.values(times).reduce(function(a,b){return a+b;},0);\n\nlet zones = {};\n['BODY','FL','FR','HL','HR'].forEach(function(k){\n    let t=times[k], h=hits[k];\n    zones[k]={\n        hits:        h,\n        time_sec:    t,\n        pref_pct:    totalTime>1e-9 ? 100*t/totalTime : NaN,\n        sec_per_hit: h>0 ? t/h : NaN\n    };\n});\n\n// best_zone from plugin is authoritative; recompute best_pct\nlet best_zone = d.best_zone || 'NO_TARGET';\nlet best_pct  = null;\nif (best_zone!=='NO_TARGET' && zones[best_zone]) {\n    let bp=zones[best_zone].pref_pct;\n    best_pct = isFinite(bp) ? parseFloat(bp.toFixed(1)) : null;\n}\n\nfunction nf(v){return (v!=null&&v!==undefined)?parseFloat(v):NaN;}\n\nlet out = {\n    zones,\n    best_zone,\n    best_pct,\n    current_zone:       d.current_zone  || 'NO_TARGET',\n    nearest_label:      d.current_zone  || 'NO_TARGET',\n    nearest_t:          NaN,\n    nose_detected:      d.valid ? 1 : 0,\n    face_state:         d.face_state    || 'UNKNOWN',\n    state_stability:    nf(d.state_stability),\n    distance_px:        nf(d.dist_px),\n    distance_norm:      nf(d.dist_norm),\n    gaze_forward_norm:  nf(d.gaze_fwd),\n    gaze_lateral_norm:  nf(d.gaze_lat),\n    gaze_angle_deg:     nf(d.gaze_angle),\n    lick_axis_score:    NaN,\n    lick_lateral_score: NaN,\n    valid:              d.valid ? 1 : 0,\n    frame:              parseInt(d.frame    || 0),\n    time_sec:           nf(d.time_sec),\n    video_path:         ''\n};\n\nglobal.set('lick_s2_latest', out);\nmsg.payload = out;\nreturn [msg, msg, msg];",
