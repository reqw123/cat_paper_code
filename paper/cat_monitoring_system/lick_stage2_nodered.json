  {
    "id": "136f39d94fe987e6",
    "type": "ui_template",
    "z": "889faede23dd76c6",
    "group": "lk_g3",
    "name": "P1 關鍵即時指標",
    "order": 1,
    "width": "0",
    "height": "9",
    "format": "<style>\n.lk1h{font-family:'Microsoft JhengHei',sans-serif;padding:10px;background:#0d1117;border-radius:14px;height:100%;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:8px;box-sizing:border-box}\n.lk1h-card{border-radius:12px;padding:12px 10px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;border:1px solid rgba(255,255,255,.07);transition:border-color .4s,background .4s;overflow:hidden;min-width:0}\n.lk1h-lbl{font-size:9px;font-weight:700;color:rgba(255,255,255,.35);letter-spacing:1px;text-transform:uppercase;margin-bottom:6px}\n.lk1h-ico{font-size:30px;line-height:1;margin-bottom:5px}\n.lk1h-val{font-size:18px;font-weight:800;color:#fff;line-height:1.2}\n.lk1h-sub{font-size:9px;color:rgba(255,255,255,.38);margin-top:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}\n.c-zone-body{background:linear-gradient(160deg,rgba(249,168,37,.18),rgba(249,168,37,.04))!important;border-color:rgba(249,168,37,.45)!important}\n.c-zone-limb{background:linear-gradient(160deg,rgba(30,136,229,.18),rgba(30,136,229,.04))!important;border-color:rgba(30,136,229,.45)!important}\n.c-zone-none{background:rgba(255,255,255,.03);border-color:rgba(255,255,255,.07)}\n.c-face-front{background:linear-gradient(160deg,rgba(76,175,80,.18),rgba(76,175,80,.04))!important;border-color:rgba(76,175,80,.45)!important}\n.c-face-back{background:linear-gradient(160deg,rgba(33,150,243,.18),rgba(33,150,243,.04))!important;border-color:rgba(33,150,243,.45)!important}\n.c-face-fv{background:linear-gradient(160deg,rgba(255,112,67,.18),rgba(255,112,67,.04))!important;border-color:rgba(255,112,67,.45)!important}\n.c-stab{background:rgba(156,39,176,.07);border-color:rgba(156,39,176,.3)}\n.c-time{background:rgba(0,188,212,.06);border-color:rgba(0,188,212,.25)}\n.lk1h-ring{width:52px;height:52px;margin:2px auto 4px}\n.lk1h-ring circle{transition:stroke-dasharray .5s ease}\n@keyframes lk1h-beat{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.7;transform:scale(1.08)}}\n.c-zone-body .lk1h-ico,.c-zone-limb .lk1h-ico{animation:lk1h-beat 1.2s ease-in-out infinite}\n.lk1h-time{font-size:26px;font-weight:900;color:#fff;font-variant-numeric:tabular-nums;letter-spacing:.5px;margin:2px 0}\n.lk1h-nose-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:4px;vertical-align:middle}\n.nose-on{background:#4caf50;box-shadow:0 0 6px #4caf50}\n.nose-off{background:#555}\n</style>\n<div class='lk1h'>\n  <div class='lk1h-card' ng-class='zoneClass()'>\n    <div class='lk1h-lbl'>接觸區域</div>\n    <div class='lk1h-ico'>{{zoneIcon()}}</div>\n    <div class='lk1h-val'>{{zoneName()}}</div>\n    <div class='lk1h-sub'><span class='lk1h-nose-dot' ng-class=\"p().nose_detected?'nose-on':'nose-off'\"></span>{{p().nearest_label||'—'}}</div>\n  </div>\n  <div class='lk1h-card' ng-class='faceClass()'>\n    <div class='lk1h-lbl'>頭部面向</div>\n    <div class='lk1h-ico'>{{faceIcon()}}</div>\n    <div class='lk1h-val'>{{faceLabel()}}</div>\n    <div class='lk1h-sub'>耳距 {{p().valid?'✓ 有效':'✗ 無效'}}</div>\n  </div>\n  <div class='lk1h-card c-stab'>\n    <div class='lk1h-lbl'>判定穩定度</div>\n    <svg class='lk1h-ring' viewBox='0 0 54 54'>\n      <circle cx='27' cy='27' r='21' fill='none' stroke='rgba(255,255,255,.08)' stroke-width='5'/>\n      <circle cx='27' cy='27' r='21' fill='none' ng-attr-stroke='{{stabColor()}}' stroke-width='5'\n        ng-attr-stroke-dasharray='{{stabDash()}}' stroke-linecap='round' transform='rotate(-90 27 27)'/>\n    </svg>\n    <div class='lk1h-val'>{{stabPct()}}<span style='font-size:12px;font-weight:400'>%</span></div>\n    <div class='lk1h-sub'>{{faceStateShort()}}</div>\n  </div>\n  <div class='lk1h-card c-time'>\n    <div class='lk1h-lbl'>影片時間</div>\n    <div class='lk1h-ico' style='font-size:20px;margin-bottom:2px'>⏱</div>\n    <div class='lk1h-time'>{{fmtTime()}}</div>\n    <div class='lk1h-sub'>Frame {{p().frame||0}}</div>\n  </div>\n</div>\n<script>\n(function(scope){\n  function p(){return scope.msg&&scope.msg.payload||{};}\n  scope.p=p;\n  scope.zoneIcon=function(){return {BODY_CENTER:'🐈',FL:'🐾',FR:'🐾',HL:'🐾',HR:'🐾',NO_TARGET:'◻'}[p().current_zone]||'◻';};\n  scope.zoneName=function(){return {BODY_CENTER:'身體中心',FL:'前左腳',FR:'前右腳',HL:'後左腳',HR:'後右腳',NO_TARGET:'無接觸'}[p().current_zone]||'無接觸';};\n  scope.zoneClass=function(){var z=p().current_zone;if(z==='BODY_CENTER')return 'lk1h-card c-zone-body';if(z&&z!=='NO_TARGET')return 'lk1h-card c-zone-limb';return 'lk1h-card c-zone-none';};\n  scope.faceIcon=function(){return {FACING_CAMERA:'🎯',FRONT_LEFT:'↖',FRONT_RIGHT:'↗',BACK_VIEW:'↩',FRONT_VIEW:'🚧',UNKNOWN:'?',NO_CAT:'—'}[p().face_state]||'?';};\n  scope.faceLabel=function(){return {FACING_CAMERA:'正面朝鏡',FRONT_LEFT:'前左',FRONT_RIGHT:'前右',BACK_VIEW:'背向鏡頭',FRONT_VIEW:'前視守門',UNKNOWN:'未知',NO_CAT:'無貓'}[p().face_state]||'—';};\n  scope.faceClass=function(){var s=p().face_state;if(!s)return 'lk1h-card';if(s==='BACK_VIEW')return 'lk1h-card c-face-back';if(s==='FRONT_VIEW')return 'lk1h-card c-face-fv';if(s&&(s.includes('FRONT')||s==='FACING_CAMERA'))return 'lk1h-card c-face-front';return 'lk1h-card';};\n  scope.stabPct=function(){var v=p().state_stability;return (v!=null&&!isNaN(v))?Math.round(v*100):0;};\n  scope.stabColor=function(){var v=scope.stabPct();return v>=80?'#66bb6a':v>=50?'#ffd54f':'#ef9a9a';};\n  scope.stabDash=function(){var c=2*Math.PI*21,r=scope.stabPct()/100;return (c*r)+' '+(c*(1-r));};\n  scope.faceStateShort=function(){return {FACING_CAMERA:'正面',FRONT_LEFT:'前左',FRONT_RIGHT:'前右',BACK_VIEW:'背向',FRONT_VIEW:'守門',UNKNOWN:'未知',NO_CAT:'無貓'}[p().face_state]||'—';};\n  scope.fmtTime=function(){var s=p().time_sec||0;var m=Math.floor(s/60),sec=Math.floor(s%60);return m+':'+(sec<10?'0':'')+sec;};\n})(scope);\n</script>",
