    "format": "<style>\n.sv-wrap{height:100%;display:flex;flex-direction:column;background:#060a0f;border-radius:10px;overflow:hidden;}\n.sv-bar{height:42px;flex-shrink:0;display:flex;align-items:center;gap:8px;padding:0 12px;background:linear-gradient(135deg,rgba(0,14,8,.96),rgba(2,20,12,.96));border-bottom:1px solid rgba(0,255,136,.12);}\n.sv-dot{width:8px;height:8px;border-radius:50%;background:#444;flex-shrink:0;transition:background .4s,box-shadow .4s;}\n.sv-label{flex:1;font-size:11px;font-weight:700;color:rgba(0,255,136,.72);letter-spacing:.6px;}\n.sv-ib{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;background:rgba(0,255,136,.06);border:1px solid rgba(0,255,136,.18);color:#fff;transition:all .18s;flex-shrink:0;-webkit-tap-highlight-color:transparent;touch-action:manipulation;font-size:16px;}\n.sv-ib:hover{background:rgba(0,255,136,.22);border-color:rgba(0,255,136,.6);transform:scale(1.1);}\n.sv-ib.sv-dis{opacity:.28;cursor:default;pointer-events:none;}\n.sv-ib.sv-on{background:rgba(0,255,136,.18)!important;color:#00ff88!important;border-color:rgba(0,255,136,.42)!important;}\n.sv-ib.sv-vc{background:rgba(66,165,245,.07);border-color:rgba(66,165,245,.22);}\n.sv-ib.sv-vc:not(.sv-dis):hover{background:rgba(66,165,245,.25);border-color:rgba(66,165,245,.7);transform:scale(1.1);}\n.sv-ib.sv-vc.sv-flash{background:rgba(66,165,245,.45)!important;border-color:#42a5f5!important;}\n.sv-body{flex:1;position:relative;background:#000;min-height:0;overflow:hidden;}\n.sv-offline{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:rgba(255,255,255,.22);font-size:12px;pointer-events:none;}\n.sv-off-ico{font-size:36px;opacity:.28;}\n.sv-rh{position:absolute;z-index:10001;display:none;}\n.sv-wrap.sv-floating .sv-rh{display:block;}\n.sv-rh-n{top:0;left:10px;right:10px;height:7px;cursor:n-resize;}\n.sv-rh-s{bottom:0;left:10px;right:10px;height:7px;cursor:s-resize;}\n.sv-rh-w{left:0;top:10px;bottom:10px;width:7px;cursor:w-resize;}\n.sv-rh-e{right:0;top:10px;bottom:10px;width:7px;cursor:e-resize;}\n.sv-rh-nw{top:0;left:0;width:12px;height:12px;cursor:nw-resize;}\n.sv-rh-ne{top:0;right:0;width:12px;height:12px;cursor:ne-resize;}\n.sv-rh-sw{bottom:0;left:0;width:12px;height:12px;cursor:sw-resize;}\n.sv-rh-se{bottom:0;right:0;width:12px;height:12px;cursor:se-resize;}\n</style>\n<div class=\"sv-wrap\" id=\"lksv_wrap\">\n  <div class=\"sv-rh sv-rh-n\" data-dir=\"n\"></div>\n  <div class=\"sv-rh sv-rh-s\" data-dir=\"s\"></div>\n  <div class=\"sv-rh sv-rh-w\" data-dir=\"w\"></div>\n  <div class=\"sv-rh sv-rh-e\" data-dir=\"e\"></div>\n  <div class=\"sv-rh sv-rh-nw\" data-dir=\"nw\"></div>\n  <div class=\"sv-rh sv-rh-ne\" data-dir=\"ne\"></div>\n  <div class=\"sv-rh sv-rh-sw\" data-dir=\"sw\"></div>\n  <div class=\"sv-rh sv-rh-se\" data-dir=\"se\"></div>\n  <div class=\"sv-bar\">\n    <div class=\"sv-dot\" id=\"lksv_dot\"></div>\n    <span class=\"sv-label\">📷 LICK ANALYSIS CAM</span>\n    <div class=\"sv-ib sv-vc sv-dis\" id=\"lksv_btn_prev\" title=\"上一支影片\">⏮</div>\n    <div class=\"sv-ib sv-vc sv-dis\" id=\"lksv_btn_next\" title=\"下一支影片\">⏭</div>\n    <div class=\"sv-ib\" id=\"lksv_btn_play\" title=\"啟動串流\">▶</div>\n    <div class=\"sv-ib\" id=\"lksv_btn_float\" title=\"浮動視窗\">⧉</div>\n  </div>\n  <div class=\"sv-body\" id=\"lksv_body\">\n    <div class=\"sv-offline\" id=\"lksv_offline\">\n      <div class=\"sv-off-ico\">📹</div>\n      <div id=\"lksv_status\">按下 ▶ 啟動串流</div>\n    </div>\n  </div>\n</div>\n<script>\n(function(scope){\n  var _url='',_baseUrl='',_stream=false,_powered=false,_svTimer=null,_retryTimer=null;\n  var PFX='lksv';\n  function g(id){return document.getElementById(PFX+'_'+id);}\n\n  function videoControl(action){\n    if(!_baseUrl)return;\n    var btn=action==='prev'?g('btn_prev'):g('btn_next');\n    if(btn){btn.classList.add('sv-flash');setTimeout(function(){btn.classList.remove('sv-flash');},200);}\n    fetch(_baseUrl+'/video_control',{\n      method:'POST',\n      headers:{'Content-Type':'application/json'},\n      body:JSON.stringify({action:action})\n    }).catch(function(){});\n  }\n\n  function svOn(){\n    if(!_url||_stream)return;\n    _stream=true;\n    if(_retryTimer){clearTimeout(_retryTimer);_retryTimer=null;}\n    var body=g('body'),off=g('offline'),dot=g('dot'),btn=g('btn_play');\n    if(!body)return;\n    if(_svTimer){clearTimeout(_svTimer);_svTimer=null;}\n    var old=body.querySelector('img.sv-img');if(old)body.removeChild(old);\n    var img=document.createElement('img');\n    img.className='sv-img';\n    img.style.cssText='width:100%;height:100%;object-fit:contain;display:block;opacity:0;transition:opacity .3s;pointer-events:none;';\n    img.onload=function(){\n      this.style.opacity=1;\n      if(off)off.style.display='none';\n      if(dot){dot.style.background='#00ff88';dot.style.boxShadow='0 0 6px #00ff88';}\n      if(_svTimer){clearTimeout(_svTimer);_svTimer=null;}\n    };\n    img.onerror=function(){\n      if(!_powered)return;\n      svOff(true);\n      var st=g('status');if(st)st.textContent='串流中斷，3秒後重試...';\n      _retryTimer=setTimeout(function(){if(_powered&&!_stream)svOn();},3000);\n    };\n    if(off)off.style.display='none';\n    body.insertBefore(img,off);\n    img.src=_url;\n    if(btn){btn.textContent='⏹';btn.title='停止串流';btn.classList.add('sv-on');}\n    _svTimer=setTimeout(function(){\n      var ci=body&&body.querySelector('img.sv-img');\n      if(ci&&!ci.naturalWidth){\n        if(!_powered)return;\n        svOff(true);\n        var st=g('status');if(st)st.textContent='連線逾時，3秒後重試...';\n        _retryTimer=setTimeout(function(){if(_powered&&!_stream)svOn();},3000);\n      }\n    },10000);\n  }\n\n  function svOff(internal){\n    _stream=false;\n    if(_svTimer){clearTimeout(_svTimer);_svTimer=null;}\n    var body=g('body'),off=g('offline'),dot=g('dot'),btn=g('btn_play');\n    var old=body&&body.querySelector('img.sv-img');if(old)body.removeChild(old);\n    if(off)off.style.display='flex';\n    if(dot){dot.style.background=_url?'#f5a623':'#444';dot.style.boxShadow=_url?'0 0 4px rgba(245,166,35,.5)':'none';}\n    if(!internal){\n      _powered=false;\n      if(_retryTimer){clearTimeout(_retryTimer);_retryTimer=null;}\n      if(btn){btn.textContent='▶';btn.title='啟動串流';btn.classList.remove('sv-on');}\n      var st=g('status');if(st)st.textContent='按下 ▶ 啟動串流';\n    }\n  }\n\n  var _btn=g('btn_play');\n  if(_btn&&!_btn._bound){\n    _btn._bound=true;\n    _btn.addEventListener('click',function(e){\n      e.stopPropagation();\n      if(_powered){\n        svOff(false);\n      }else{\n        _powered=true;\n        if(_url){svOn();}else{\n          var st=g('status'),dot=g('dot'),btn=g('btn_play');\n          if(st)st.textContent='等待串流服務器...';\n          if(dot){dot.style.background='#aaa';dot.style.boxShadow='0 0 4px rgba(170,170,170,.4)';}\n          if(btn){btn.textContent='⏹';btn.title='停止串流';btn.classList.add('sv-on');}\n        }\n      }\n    });\n  }\n\n  function urlReady(url){\n    _url=url;\n    var m=url.match(/^(https?:\\/\\/[^\\/]+)/);\n    if(m)_baseUrl=m[1];\n    var dot=g('dot');\n    if(dot&&!_stream){dot.style.background='#f5a623';dot.style.boxShadow='0 0 4px rgba(245,166,35,.5)';}\n    var prev=g('btn_prev'),next=g('btn_next');\n    if(prev&&!prev._bound){prev._bound=true;prev.classList.remove('sv-dis');prev.addEventListener('click',function(e){e.stopPropagation();videoControl('prev');});}\n    if(next&&!next._bound){next._bound=true;next.classList.remove('sv-dis');next.addEventListener('click',function(e){e.stopPropagation();videoControl('next');});}\n    if(_powered&&!_stream)svOn();\n  }\n\n  var _floating=false,_origCS='';\n  function _dragBar(e){\n    var wrap=document.getElementById('lksv_wrap');\n    if(!wrap||!_floating)return;\n    var r=wrap.getBoundingClientRect(),sx=e.clientX,sy=e.clientY,sl=r.left,st=r.top;\n    function mv(e){wrap.style.left=(sl+e.clientX-sx)+'px';wrap.style.top=(st+e.clientY-sy)+'px';}\n    function up(){document.removeEventListener('mousemove',mv);document.removeEventListener('mouseup',up);}\n    document.addEventListener('mousemove',mv);document.addEventListener('mouseup',up);e.preventDefault();\n  }\n  function _startResize(e,dir){\n    var wrap=document.getElementById('lksv_wrap');\n    if(!wrap||!_floating)return;\n    e.preventDefault();e.stopPropagation();\n    var r=wrap.getBoundingClientRect(),sx=e.clientX,sy=e.clientY,oL=r.left,oT=r.top,oW=r.width,oH=r.height,minW=240,minH=160;\n    function mv(e){\n      var dx=e.clientX-sx,dy=e.clientY-sy,l=oL,t=oT,w=oW,h=oH;\n      if(dir.indexOf('e')>=0)w=Math.max(minW,oW+dx);\n      if(dir.indexOf('s')>=0)h=Math.max(minH,oH+dy);\n      if(dir.indexOf('w')>=0){w=Math.max(minW,oW-dx);if(w>minW)l=oL+dx;}\n      if(dir.indexOf('n')>=0){h=Math.max(minH,oH-dy);if(h>minH)t=oT+dy;}\n      wrap.style.left=l+'px';wrap.style.top=t+'px';wrap.style.width=w+'px';wrap.style.height=h+'px';\n    }\n    function up(){document.removeEventListener('mousemove',mv);document.removeEventListener('mouseup',up);}\n    document.addEventListener('mousemove',mv);document.addEventListener('mouseup',up);\n  }\n  function toggleFloat(){\n    var wrap=document.getElementById('lksv_wrap');\n    var bar=wrap&&wrap.querySelector('.sv-bar');\n    var btn=g('btn_float');\n    if(!wrap)return;\n    if(!_floating){\n      _floating=true;\n      _origCS=wrap.getAttribute('style')||'';\n      var r=wrap.getBoundingClientRect();\n      wrap.style.cssText='position:fixed;left:'+r.left+'px;top:'+r.top+'px;width:'+r.width+'px;height:'+r.height+'px;z-index:9999;border-radius:10px;box-shadow:0 12px 48px rgba(0,0,0,.85);overflow:hidden;min-width:240px;min-height:160px;';\n      wrap.classList.add('sv-floating');\n      if(bar){bar.style.cursor='move';bar.addEventListener('mousedown',_dragBar);}\n      if(btn){btn.textContent='⊞';btn.title='返回原位';btn.classList.add('sv-on');}\n    }else{\n      _floating=false;\n      if(bar){bar.style.cursor='';bar.removeEventListener('mousedown',_dragBar);}\n      wrap.classList.remove('sv-floating');\n      wrap.setAttribute('style',_origCS);\n      if(btn){btn.textContent='⧉';btn.title='浮動視窗';btn.classList.remove('sv-on');}\n    }\n  }\n  var floatBtn=g('btn_float');\n  if(floatBtn)floatBtn.addEventListener('click',function(e){e.stopPropagation();toggleFloat();});\n  [].forEach.call(document.querySelectorAll('#lksv_wrap .sv-rh'),function(rh){\n    rh.addEventListener('mousedown',function(e){_startResize(e,this.getAttribute('data-dir'));});\n  });\n\n  scope.$watch('msg',function(msg){\n    if(!msg)return;\n    var ip=(msg.payload&&msg.payload.ip)?msg.payload.ip:null;\n    var url='';\n    if(ip){url='http://'+ip+':5000/stream';}\n    else if(msg.stream_url){url=msg.stream_url;}\n    if(!url||url===_url)return;\n    urlReady(url);\n  });\n})(scope);\n</script>",
