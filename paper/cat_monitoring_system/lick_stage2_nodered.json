    "format": "<style>\n.lk3{font-family:'Microsoft JhengHei',sans-serif;padding:10px 12px;background:#0d1117;border-radius:14px;height:100%;display:flex;flex-direction:column;justify-content:space-between;box-sizing:border-box}\n.lk3-sec-title{font-size:9px;font-weight:700;color:rgba(255,255,255,.3);letter-spacing:.8px;text-transform:uppercase;margin-bottom:4px}\n.lk3-hdiv{height:1px;background:rgba(255,255,255,.07);flex-shrink:0}\n.lk3-angle-row{display:flex;align-items:center;gap:10px;padding:6px 10px;background:rgba(0,188,212,.07);border:1px solid rgba(0,188,212,.2);border-radius:10px}\n.lk3-angle-num{font-size:32px;font-weight:900;color:#fff;line-height:1;font-variant-numeric:tabular-nums;flex-shrink:0}\n.lk3-angle-deg{font-size:13px;color:rgba(0,188,212,.8);font-weight:700}\n.lk3-angle-lbl{font-size:9px;color:rgba(255,255,255,.28);letter-spacing:.4px}\n.lk3-gaze-row{display:flex;align-items:center;gap:8px}\n.lk3-gaze-lbl{font-size:10px;color:rgba(255,255,255,.38);width:44px;flex-shrink:0}\n.lk3-gaze-val{font-size:13px;font-weight:700;width:48px;flex-shrink:0;text-align:right}\n.lk3-track{flex:1;height:8px;background:rgba(255,255,255,.06);border-radius:99px;overflow:visible;position:relative}\n.lk3-fill{position:absolute;height:100%;border-radius:99px;top:0;transition:all .4s}\n.lk3-fill-pos{background:linear-gradient(90deg,#43a047,#66bb6a)}\n.lk3-fill-neg{background:linear-gradient(90deg,#e53935,#ef9a9a)}\n.lk3-vline{position:absolute;top:-2px;left:50%;width:2px;height:12px;background:rgba(255,255,255,.18);transform:translateX(-50%)}\n.lk3-dist-row{display:flex;gap:8px}\n.lk3-dist-card{flex:1;padding:7px 10px;border-radius:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07)}\n.lk3-dist-lbl{font-size:9px;color:rgba(255,255,255,.35);letter-spacing:.5px;margin-bottom:4px}\n.lk3-dist-val{font-size:18px;font-weight:800;color:#fff;line-height:1}\n.lk3-dist-unit{font-size:9px;color:rgba(255,255,255,.3);margin-left:2px}\n.lk3-badge{display:inline-flex;align-items:center;padding:2px 7px;border-radius:99px;font-size:10px;font-weight:700;margin-top:4px}\n.lk3-ok{background:rgba(76,175,80,.18);color:#81c784}\n.lk3-no{background:rgba(244,67,54,.18);color:#ef9a9a}\n</style>\n<div class='lk3'>\n  <div class='lk3-sec-title'>注視角</div>\n  <div class='lk3-angle-row'>\n    <div class='lk3-angle-num'>{{fmtDeg()}}<span class='lk3-angle-deg'>°</span></div>\n    <div class='lk3-angle-lbl'>gaze_angle_deg</div>\n  </div>\n  <div class='lk3-hdiv'></div>\n  <div class='lk3-sec-title'>頭部方向向量</div>\n  <div class='lk3-gaze-row'>\n    <span class='lk3-gaze-lbl'>前後</span>\n    <span class='lk3-gaze-val' ng-style=\"{color:sc(p().gaze_forward_norm)}\">{{f3(p().gaze_forward_norm)}}</span>\n    <div class='lk3-track'>\n      <div class='lk3-vline'></div>\n      <div class='lk3-fill' ng-class=\"p().gaze_forward_norm>=0?'lk3-fill-pos':'lk3-fill-neg'\" ng-style='barStyle(p().gaze_forward_norm)'></div>\n    </div>\n  </div>\n  <div class='lk3-gaze-row'>\n    <span class='lk3-gaze-lbl'>左右</span>\n    <span class='lk3-gaze-val' ng-style=\"{color:sc(p().gaze_lateral_norm)}\">{{f3(p().gaze_lateral_norm)}}</span>\n    <div class='lk3-track'>\n      <div class='lk3-vline'></div>\n      <div class='lk3-fill' ng-class=\"p().gaze_lateral_norm>=0?'lk3-fill-pos':'lk3-fill-neg'\" ng-style='barStyle(p().gaze_lateral_norm)'></div>\n    </div>\n  </div>\n  <div class='lk3-hdiv'></div>\n  <div class='lk3-sec-title'>耳距</div>\n  <div class='lk3-dist-row'>\n    <div class='lk3-dist-card'>\n      <div class='lk3-dist-lbl'>PIXEL</div>\n      <div><span class='lk3-dist-val'>{{f1(p().distance_px)}}</span><span class='lk3-dist-unit'>px</span></div>\n      <span class='lk3-badge' ng-class=\"p().valid?'lk3-ok':'lk3-no'\">{{p().valid?'✓ 有效':'✗ 無效'}}</span>\n    </div>\n    <div class='lk3-dist-card'>\n      <div class='lk3-dist-lbl'>NORMALIZED</div>\n      <div><span class='lk3-dist-val' style='font-size:15px'>{{f4(p().distance_norm)}}</span></div>\n    </div>\n  </div>\n</div>\n<script>\n(function(scope){\n  function p(){return scope.msg&&scope.msg.payload||{};}\n  scope.p=p;\n  var fn=function(v,d){return (v==null||isNaN(v)||!isFinite(v))?'N/A':parseFloat(v).toFixed(d);};\n  scope.f1=function(v){return fn(v,1);};  scope.f3=function(v){return fn(v,3);};  scope.f4=function(v){return fn(v,5);};\n  scope.fmtDeg=function(){return fn(p().gaze_angle_deg,1);};\n  scope.sc=function(v){return (!v||isNaN(v))?'#888':v>=0?'#81c784':'#ef9a9a';};\n  scope.barStyle=function(v){\n    if(!v||isNaN(v))return {width:'0%',left:'50%'};\n    var pct=Math.min(50,Math.abs(parseFloat(v))/1.5*50);\n    return v>=0?{width:pct+'%',left:'50%'}:{width:pct+'%',left:(50-pct)+'%'};\n  };\n})(scope);\n</script>",
