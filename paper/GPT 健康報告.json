        "format": "<style>\n.vr-wrap{font-family:'Microsoft JhengHei','PingFang TC',sans-serif;background:#0d1117;border-radius:12px;padding:18px}\n.vr-title{color:rgba(255,255,255,.6);font-size:13px;margin-bottom:12px}\n.vr-empty{color:rgba(255,255,255,.2);font-style:italic;font-size:13px;text-align:center;padding:20px 0 10px}\n.vr-thumb{width:100%;border-radius:8px;border:1px solid rgba(255,255,255,.12);display:block;margin-bottom:10px}\n.vr-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;font-size:13px;color:rgba(255,255,255,.75)}\n.vr-label{color:rgba(255,255,255,.35);font-size:12px;min-width:54px}\n.vr-file{margin-top:8px;font-size:10px;color:rgba(255,255,255,.2);word-break:break-all}\n.rec-btn{margin-top:12px;width:100%;padding:11px 0;border-radius:99px;border:none;cursor:pointer;font-family:inherit;font-size:14px;font-weight:600;background:linear-gradient(135deg,#c0392b,#e74c3c);color:#fff;box-shadow:0 4px 16px rgba(231,76,60,.4);transition:transform .15s,box-shadow .2s}\n.rec-btn:hover{transform:translateY(-2px);box-shadow:0 6px 22px rgba(231,76,60,.55)}\n.rec-btn:active{transform:scale(.96)}\n.rec-btn:disabled{opacity:.45;cursor:not-allowed;transform:none}\n</style>\n<div class=\"vr-wrap\">\n  <div class=\"vr-title\">🎥 最近錄影</div>\n  <div ng-if=\"!msg.payload.path\" class=\"vr-empty\">尚未錄製<br><small>點擊下方按鈕或透過 Messenger 發送 /camera 觸發</small></div>\n  <div ng-if=\"msg.payload.path\">\n    <img ng-if=\"msg.payload.thumbnail\" class=\"vr-thumb\" ng-src=\"{{msg.payload.thumbnail}}\">\n    <div class=\"vr-row\"><span class=\"vr-label\">🕒 時間</span>{{msg.payload.ts}}</div>\n    <div class=\"vr-row\"><span class=\"vr-label\">⏱ 時長</span>{{msg.payload.duration}} 秒（{{msg.payload.frames}} 幀）</div>\n    <div class=\"vr-file\">📁 {{msg.payload.path}}</div>\n  </div>\n  <button class=\"rec-btn\" ng-click=\"record()\" ng-disabled=\"recording\">{{recording ? '錄製中...' : '🔴 立即錄影（最近 5 秒）'}}</button>\n</div>\n<script>\n(function(scope){\n  scope.recording = false;\n  scope.record = function(){\n    if(scope.recording) return;\n    scope.recording = true;\n    fetch('/ui-trigger-record', {method:'POST'})\n      .catch(function(){}).finally(function(){ setTimeout(function(){ scope.recording = false; scope.$apply(); }, 3000); });\n  };\n})(scope);\n</script>",
