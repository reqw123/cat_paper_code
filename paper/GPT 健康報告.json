        "func": "let token = global.get('FB_TOKEN');\n\n// ── 指令清單 ──────────────────────────────\nlet cmdList = [\n  '🐱 貓咪監測系統 · 可用指令',\n  '─────────────────',\n  '哈基米　→ AI 健康分析報告（需 10–20 秒）',\n  '/camera → 錄製最近 5 秒行為影片',\n  '/status → 查詢即時行為與今日統計',\n  '/help　 → 顯示此說明'\n].join('\\n');\n\n// ── 公告欄（自訂內容） ──────────────────────\nlet bulletin = [\n  '',\n  '📌 公告欄 · 致即將畢業的你',\n  '─────────────────',\n  '你從零蓋了一套端對端系統：',\n  'YOLO-Pose → ST-GCN → Node-RED → GPT',\n  '連貓咪都受到 AI 守護，厲害了。',\n  '',\n  '🔔 畢業前最後叮嚀',\n  '□ 消融實驗數字整理進論文了嗎？',\n  '□ Dashboard 截圖放投影片了嗎？',\n  '□ 教授 feedback 都回應了嗎？',\n  '□ 論文初稿交前記得備份三份！',\n  '',\n  '終點就在前面了，',\n  '論文寫完的那天，貓咪陪你慶祝 🎓'\n].join('\\n');\n\nlet fullText = cmdList + bulletin;\n\nmsg.headers = { 'Content-Type': 'application/json' };\nmsg.url = 'https://graph.facebook.com/v23.0/me/messages?access_token=' + token;\nmsg.payload = { recipient: { id: msg.sender }, message: { text: fullText } };\nreturn msg;",
