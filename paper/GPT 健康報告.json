        "id": "a7ab1fe987e63b26",
        "type": "function",
        "z": "f374f5debb3b6a37",
        "name": "解析Messenger訊息",
        "func": "let entry = msg.payload && msg.payload.entry && msg.payload.entry[0];\nlet event = entry && entry.messaging && entry.messaging[0];\n\n// 過濾：結構不完整（delivery/read receipt）\nif (!event || !event.message) { return null; }\n\n// 過濾：echo 事件（bot 自己送出的訊息被 FB 回送）\nif (event.message.is_echo) { return null; }\n\n// 過濾：沒有文字的訊息（貼圖、圖片等）\nlet text = event.message.text || '';\nif (!text) { return null; }\n\nmsg.sender = event.sender.id;\nmsg.text = text;\n\nreturn msg;",
