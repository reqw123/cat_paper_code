    {
        "id": "b72e11992f8fecb4",
        "type": "function",
        "z": "f374f5debb3b6a37",
        "name": "處理截圖",
        "func": "let data = msg.payload;\nlet sender = msg._sender;\nlet token = global.get('FB_TOKEN');\n\n// Flask 失敗或 buffer 空 → 通知使用者\nif (!data || data.error || !data.path) {\n    node.warn('video_clip failed: ' + JSON.stringify(data));\n    if (sender) {\n        let errMsg = RED.util.cloneMessage(msg);\n        errMsg.headers = { 'Content-Type': 'application/json' };\n        errMsg.url = 'https://graph.facebook.com/v23.0/me/messages?access_token=' + token;\n        errMsg.payload = {\n            recipient: { id: sender },\n            message: { text: '⚠️ 錄影失敗。\\n可能原因：系統尚未啟動、buffer 尚未累積（請等 5 秒後再試），或 Flask 未執行。' }\n        };\n        node.send([null, null, errMsg]);\n    }\n    return null;\n}\n\nlet ts       = data.ts       || new Date().toLocaleString('zh-TW');\nlet path     = data.path     || '';\nlet duration = data.duration || 0;\nlet frames   = data.frames   || 0;\n\n// out1: null（Flask 已儲存，不需 Node-RED 再寫檔）\nlet msg1 = null;\n\n// out2: Dashboard 顯示（含縮圖）\nlet msg2 = RED.util.cloneMessage(msg);\nmsg2.payload = { ts, path, duration, frames, thumbnail: data.thumbnail || '' };\n\n// out3: Messenger 通知\nlet msg3 = null;\nif (sender) {\n    msg3 = RED.util.cloneMessage(msg);\n    msg3.headers = { 'Content-Type': 'application/json' };\n    msg3.url = 'https://graph.facebook.com/v23.0/me/messages?access_token=' + token;\n    msg3.payload = {\n        recipient: { id: sender },\n        message: { text: '🎥 錄影完成！\\n🕒 ' + ts + '\\n⏱ 時長：' + duration + ' 秒（' + frames + ' 幀）\\n📁 ' + path }\n    };\n}\n\nreturn [msg1, msg2, msg3];",
