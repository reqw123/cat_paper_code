        "name": "解析訊息",
        "func": "let VERIFY_TOKEN = 'cat_ai_system';\n\nlet mode = msg.req.query['hub.mode'];\nlet token = msg.req.query['hub.verify_token'];\nlet challenge = msg.req.query['hub.challenge'];\n\nif(mode && token){\n\n    if(mode === 'subscribe' && token === VERIFY_TOKEN){\n\n        msg.payload = challenge;\n\n        return [msg,null];\n    }\n}\n\nmsg.statusCode = 403;\nmsg.payload = 'Forbidden';\n\nreturn [null,msg];",
