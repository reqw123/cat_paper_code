        "name": "/status 回覆",
        "func": "let d = msg.payload || {};\nlet stats = d.today_stats || {};\nlet behavior = ['走動','舔舐','搔抓','甩頭','靜止'];\nlet bId = d.latest_behavior;\nlet bName = (bId >= 0 && bId <= 4) ? behavior[bId] : '偵測中';\nlet conf = Math.round((d.latest_confidence || 0) * 100);\nlet score = d.activity_score || 0;\nlet lines = [\n  '📊 目前狀態',\n  '行為：' + bName + '（信心 ' + conf + '%）',\n  '活動力：' + score,\n  '',\n  '📋 今日統計',\n  '走動 ' + (stats.walk||0) + ' 次　舔舐 ' + (stats.lick||0) + ' 次',\n  '搔抓 ' + (stats.scratch||0) + ' 次　甩頭 ' + (stats.shake||0) + ' 次',\n  '靜止 ' + (stats.stop||0) + ' 次',\n  '活動時長 ' + Math.round((stats.active_time||0)/60) + ' 分'\n];\nlet token = global.get('FB_TOKEN');\nmsg.headers = { 'Content-Type': 'application/json' };\nmsg.url = 'https://graph.facebook.com/v23.0/me/messages?access_token=' + token;\nmsg.payload = { recipient: { id: msg._sender }, message: { text: lines.join('\\n') } };\nreturn msg;",
