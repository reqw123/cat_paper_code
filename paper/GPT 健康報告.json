    {
        "id": "bf79b638e3d01d61",
        "type": "ui_template",
        "z": "f374f5debb3b6a37",
        "group": "901efcd57b51e81f",
        "name": "AI健康卡片",
        "order": 2,
        "width": "24",
        "height": "22",
        "format": "<style>\n*{box-sizing:border-box;margin:0;padding:0}\n@keyframes pulse-ring{0%,100%{opacity:.18}50%{opacity:.38}}\n@keyframes shimmer{0%{background-position:200% center}100%{background-position:-200% center}}\n@keyframes fade-in{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}\n@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}\n@keyframes breath{0%,100%{opacity:.6;transform:scale(.98)}50%{opacity:1;transform:scale(1)}}\n@keyframes prog{0%{width:0%}100%{width:95%}}\n@keyframes dots{0%{content:'.'}33%{content:'..'}66%,100%{content:'...'}}\n\n.page{\n  font-family:'Microsoft JhengHei','PingFang TC','Segoe UI',sans-serif;\n  background:#0d1117;border-radius:16px;\n  position:relative;overflow:hidden;\n}\n.bg-layer{\n  position:absolute;inset:0;\n  background-image:url('/1.gif');\n  background-size:cover;background-position:center;\n  opacity:.10;pointer-events:none;z-index:0;\n}\n.orb{position:absolute;border-radius:50%;pointer-events:none;z-index:0}\n.orb1{width:400px;height:400px;top:-100px;right:-80px;\n  background:radial-gradient(circle,rgba(29,158,117,.22) 0%,transparent 70%);\n  animation:pulse-ring 6s ease-in-out infinite}\n.orb2{width:280px;height:280px;bottom:-60px;left:-50px;\n  background:radial-gradient(circle,rgba(55,138,221,.18) 0%,transparent 70%);\n  animation:pulse-ring 8s ease-in-out infinite 2s}\n\n.inner{\n  position:relative;z-index:1;padding:24px;\n  max-height:800px;overflow-y:auto;\n  scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.15) transparent;\n}\n.inner::-webkit-scrollbar{width:5px}\n.inner::-webkit-scrollbar-thumb{background:rgba(255,255,255,.15);border-radius:99px}\n\n/* HEADER */\n.hdr{display:flex;align-items:center;gap:12px;margin-bottom:0;\n  padding-bottom:18px;border-bottom:1px solid rgba(255,255,255,.08)}\n.hdr-ico{\n  width:50px;height:50px;border-radius:12px;flex-shrink:0;\n  background:rgba(29,158,117,.18);border:1px solid rgba(29,158,117,.35);\n  display:flex;align-items:center;justify-content:center}\n.hdr-ico i{font-size:24px;color:#5DCAA5}\n.hdr-info{flex:1}\n.hdr-title{\n  font-size:18px;font-weight:600;\n  background:linear-gradient(90deg,#e2e8f0,#9FE1CB 55%,#85B7EB);\n  background-size:200% auto;\n  -webkit-background-clip:text;-webkit-text-fill-color:transparent;\n  background-clip:text;animation:shimmer 5s linear infinite}\n.hdr-sub{font-size:13px;color:rgba(255,255,255,.4);margin-top:3px}\n.hdr-badge{\n  font-size:12px;padding:5px 13px;border-radius:99px;flex-shrink:0;\n  display:flex;align-items:center;gap:5px;transition:all .4s}\n.badge-idle   {background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.35)}\n.badge-loading{background:rgba(239,159,39,.15);border:1px solid rgba(239,159,39,.35);color:#EF9F27}\n.badge-done   {background:rgba(29,158,117,.15);border:1px solid rgba(29,158,117,.3);color:#5DCAA5}\n\n/* ── TRIGGER ZONE（header 正下方，置中）── */\n.trigger-zone{\n  display:flex;flex-direction:column;align-items:center;gap:12px;\n  padding:22px 0 20px;\n  border-bottom:1px solid rgba(255,255,255,.06);\n  margin-bottom:20px;\n}\n.trigger-btn{\n  display:inline-flex;align-items:center;justify-content:center;gap:9px;\n  font-family:inherit;font-size:15px;font-weight:600;\n  padding:13px 36px;border-radius:99px;border:none;cursor:pointer;\n  transition:transform .15s,box-shadow .2s,opacity .2s;\n  outline:none;\n}\n.trigger-btn:active{transform:scale(.96)!important}\n.btn-idle{\n  background:linear-gradient(135deg,#1d9e75 0%,#378add 100%);\n  color:#fff;\n  box-shadow:0 4px 22px rgba(29,158,117,.4);\n}\n.btn-idle:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(29,158,117,.55)}\n.btn-loading{\n  background:rgba(239,159,39,.12);\n  border:1.5px solid rgba(239,159,39,.45)!important;\n  color:#EF9F27;cursor:not-allowed;\n  animation:breath 1.8s ease-in-out infinite;\n}\n.btn-done{\n  background:rgba(29,158,117,.1);\n  border:1.5px solid rgba(29,158,117,.35)!important;\n  color:#5DCAA5;\n}\n.btn-done:hover{background:rgba(29,158,117,.2);box-shadow:0 4px 18px rgba(29,158,117,.3)}\n.spin-ico{display:inline-block;animation:spin 1s linear infinite}\n\n.prog-wrap{\n  width:280px;height:3px;border-radius:99px;\n  background:rgba(255,255,255,.06);overflow:hidden;\n}\n.prog-bar{\n  height:100%;border-radius:99px;\n  background:linear-gradient(90deg,#1d9e75,#378add,#9FE1CB);\n  background-size:200%;\n  animation:shimmer 1.5s linear infinite, prog 25s linear forwards;\n}\n.trigger-hint{font-size:12px;color:rgba(255,255,255,.28)}\n.trigger-time{font-size:12px;color:rgba(255,255,255,.22)}\n\n/* LOADING BANNER */\n.loading-banner{\n  display:flex;align-items:center;gap:12px;\n  padding:14px 18px;border-radius:10px;margin-bottom:16px;\n  border:1px solid rgba(239,159,39,.22);\n  background:rgba(239,159,39,.06);\n  animation:fade-in .3s ease;\n}\n.loading-banner i{font-size:20px;color:#EF9F27}\n.lb-txt b{font-size:14px;color:rgba(255,255,255,.85);display:block;margin-bottom:2px}\n.lb-txt span{font-size:12px;color:rgba(255,255,255,.4)}\n.dots::after{content:'.';animation:dots 1.2s steps(3,end) infinite}\n\n/* CARDS */\n.cards{display:flex;flex-direction:column;gap:12px}\n.card{border-radius:10px;overflow:hidden;\n  border:1px solid rgba(255,255,255,.07);\n  background:rgba(255,255,255,.04);\n  animation:fade-in .35s ease both}\n.card:nth-child(1){animation-delay:.05s}\n.card:nth-child(2){animation-delay:.10s}\n.card:nth-child(3){animation-delay:.15s}\n.card:nth-child(4){animation-delay:.20s}\n.card:nth-child(5){animation-delay:.25s}\n.card:nth-child(6){animation-delay:.30s}\n.card-hd{display:flex;align-items:center;gap:10px;\n  padding:11px 14px;border-bottom:1px solid rgba(255,255,255,.06)}\n.ico{width:30px;height:30px;border-radius:7px;flex-shrink:0;\n  display:flex;align-items:center;justify-content:center}\n.ico i{font-size:15px}\n.c0{background:rgba(55,138,221,.2);border:1px solid rgba(55,138,221,.3)}.c0 i{color:#85B7EB}\n.c1{background:rgba(55,138,221,.2);border:1px solid rgba(55,138,221,.3)}.c1 i{color:#85B7EB}\n.c2{background:rgba(99,153,34,.2);border:1px solid rgba(99,153,34,.3)} .c2 i{color:#97C459}\n.c3{background:rgba(239,159,39,.2);border:1px solid rgba(239,159,39,.3)}.c3 i{color:#EF9F27}\n.c4{background:rgba(226,75,74,.2);border:1px solid rgba(226,75,74,.3)} .c4 i{color:#F09595}\n.c5{background:rgba(29,158,117,.2);border:1px solid rgba(29,158,117,.3)}.c5 i{color:#5DCAA5}\n.card-num{font-size:11px;color:rgba(255,255,255,.25);letter-spacing:.04em}\n.card-title{font-size:15px;font-weight:500;color:rgba(255,255,255,.9);flex:1}\n.card-body{padding:14px 16px;font-size:15px;line-height:1.9;\n  color:rgba(255,255,255,.72);white-space:pre-wrap;word-break:break-word}\n.placeholder{color:rgba(255,255,255,.22);font-style:italic}\n\n/* FOOTER */\n.ftr{display:flex;justify-content:space-between;align-items:center;\n  padding:14px 24px 18px;\n  border-top:1px solid rgba(255,255,255,.06);margin-top:4px}\n.ftr-l{display:flex;align-items:center;gap:6px;font-size:12px;color:rgba(255,255,255,.25)}\n.ftr-l i{font-size:13px}\n.ftr-r{font-size:12px;color:rgba(255,255,255,.2)}\n.links{display:flex;justify-content:center;flex-wrap:wrap;gap:6px;padding:0 24px 18px}\n.lbtn{display:inline-flex;align-items:center;gap:5px;\n  font-size:12px;padding:6px 14px;border-radius:99px;\n  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);\n  color:rgba(255,255,255,.45);text-decoration:none;transition:all .2s}\n.lbtn:hover{background:rgba(29,158,117,.15);border-color:rgba(29,158,117,.4);color:#9FE1CB}\n.lbtn i{font-size:13px}\n</style>\n\n<div class=\"page\">\n  <div class=\"bg-layer\"></div>\n  <div class=\"orb orb1\"></div>\n  <div class=\"orb orb2\"></div>\n\n  <div class=\"inner\">\n\n    <!-- HEADER -->\n    <div class=\"hdr\">\n      <div class=\"hdr-ico\"><i class=\"ti ti-report-medical\"></i></div>\n      <div class=\"hdr-info\">\n        <div class=\"hdr-title\">GPT 健康分析結果</div>\n        <div class=\"hdr-sub\">基於 ST-GCN 行為辨識資料 · 自動分析報告</div>\n      </div>\n      <div class=\"hdr-badge\" ng-class=\"badgeCls\">\n        <i ng-class=\"'ti ' + badgeIco\"></i>{{badgeTxt}}\n      </div>\n    </div>\n\n    <!-- TRIGGER ZONE：header 正下方，置中 -->\n    <div class=\"trigger-zone\">\n      <button class=\"trigger-btn\"\n              ng-class=\"btnCls\"\n              ng-click=\"triggerAnalysis()\"\n              ng-disabled=\"uiState === 'loading'\">\n        <span class=\"spin-ico\" ng-if=\"uiState === 'loading'\">\n          <i class=\"ti ti-loader-2\"></i>\n        </span>\n        <i ng-if=\"uiState !== 'loading'\" ng-class=\"'ti ' + btnIcoName\"></i>\n        {{btnLabel}}\n      </button>\n      <div class=\"prog-wrap\" ng-if=\"uiState === 'loading'\">\n        <div class=\"prog-bar\"></div>\n      </div>\n      <span class=\"trigger-hint\" ng-if=\"uiState === 'idle'\">點擊按鈕啟動 AI 健康分析</span>\n      <span class=\"trigger-time\" ng-if=\"lastTime\">上次分析：{{lastTime}}</span>\n    </div>\n\n    <!-- LOADING BANNER -->\n    <div class=\"loading-banner\" ng-if=\"uiState === 'loading'\">\n      <i class=\"ti ti-brain\"></i>\n      <div class=\"lb-txt\">\n        <b>GPT 分析中<span class=\"dots\"></span></b>\n        <span>正在讀取監測資料並呼叫 GPT，通常需要 10–20 秒</span>\n      </div>\n    </div>\n\n    <!-- RESULT CARDS -->\n    <div class=\"cards\" ng-if=\"uiState === 'done'\">\n      <div class=\"card\" ng-repeat=\"s in sections track by $index\">\n        <div class=\"card-hd\">\n          <div class=\"ico\" ng-class=\"s.cls\"><i ng-class=\"'ti ' + s.ico\"></i></div>\n          <span class=\"card-num\">0{{$index+1}}</span>\n          <span class=\"card-title\">{{s.title}}</span>\n        </div>\n        <div class=\"card-body\">{{s.body}}</div>\n      </div>\n      <div class=\"card\" ng-if=\"!sections.length && rawText\">\n        <div class=\"card-hd\">\n          <div class=\"ico c1\"><i class=\"ti ti-file-text\"></i></div>\n          <span class=\"card-num\">--</span><span class=\"card-title\">分析內容</span>\n        </div>\n        <div class=\"card-body\">{{rawText}}</div>\n      </div>\n    </div>\n\n    <!-- IDLE PLACEHOLDER -->\n    <div class=\"cards\" ng-if=\"uiState === 'idle'\">\n      <div class=\"card\">\n        <div class=\"card-hd\">\n          <div class=\"ico c1\"><i class=\"ti ti-paw\"></i></div>\n          <span class=\"card-num\">--</span>\n          <span class=\"card-title\">尚無分析資料</span>\n        </div>\n        <div class=\"card-body placeholder\">請點擊上方「開始健康分析」按鈕，系統將讀取最新監測資料並透過 GPT 產生報告。</div>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"links\">\n    <a class=\"lbtn\" href=\"https://www.merckvetmanual.com/cat-owners\" target=\"_blank\">\n      <i class=\"ti ti-external-link\"></i>默克獸醫手冊</a>\n    <a class=\"lbtn\" href=\"https://icatcare.org/advice/cat-behaviour/\" target=\"_blank\">\n      <i class=\"ti ti-external-link\"></i>iCatCare 行為指南</a>\n    <a class=\"lbtn\" href=\"https://www.avma.org/resources-tools/pet-owners/petcare/cat-care\" target=\"_blank\">\n      <i class=\"ti ti-external-link\"></i>AVMA 貓咪照護</a>\n  </div>\n  <div class=\"ftr\">\n    <div class=\"ftr-l\"><i class=\"ti ti-cpu\"></i><span>AI Cat Monitoring System</span></div>\n    <div class=\"ftr-r\">gpt-4.1-mini · Node-RED</div>\n  </div>\n</div>\n\n<script>\n(function(scope){\n  var META = [\n    {ico:'ti-droplet',       cls:'c1'},\n    {ico:'ti-run',           cls:'c2'},\n    {ico:'ti-refresh-alert', cls:'c3'},\n    {ico:'ti-shield-check',  cls:'c4'},\n    {ico:'ti-notes',         cls:'c5'}\n  ];\n\n  scope.sections = [];\n  scope.rawText  = '';\n  scope.lastTime = '';\n\n  // ── 狀態機 ──────────────────────\n  function setState(s){\n    scope.uiState = s;\n    if(s === 'idle'){\n      scope.btnCls     = 'btn-idle';\n      scope.btnIcoName = 'ti-stethoscope';\n      scope.btnLabel   = '開始健康分析';\n      scope.badgeCls   = 'badge-idle';\n      scope.badgeIco   = 'ti-clock';\n      scope.badgeTxt   = '尚未分析';\n    } else if(s === 'loading'){\n      scope.btnCls     = 'btn-loading';\n      scope.btnIcoName = 'ti-loader-2';\n      scope.btnLabel   = '分析中，請稍候...';\n      scope.badgeCls   = 'badge-loading';\n      scope.badgeIco   = 'ti-refresh';\n      scope.badgeTxt   = '分析中';\n    } else {\n      scope.btnCls     = 'btn-done';\n      scope.btnIcoName = 'ti-refresh';\n      scope.btnLabel   = '重新分析';\n      scope.badgeCls   = 'badge-done';\n      scope.badgeIco   = 'ti-circle-check';\n      scope.badgeTxt   = '已完成';\n    }\n  }\n\n  // 預設 idle，不依賴外部 msg\n  setState('idle');\n\n  // ── 按鈕觸發 ────────────────────\n  scope.triggerAnalysis = function(){\n    if(scope.uiState === 'loading') return;\n    setState('loading');\n    scope.sections = [];\n    scope.rawText  = '';\n\n    fetch('/ui-trigger-health', { method: 'POST' })\n      .then(function(r){\n        if(!r.ok) throw new Error(r.status);\n      })\n      .catch(function(e){\n        console.error('trigger failed', e);\n        setState('idle');\n      });\n  };\n\n  // ── 接收 GPT 結果 ────────────────\n  function parse(raw){\n    if(!raw || !raw.trim()) return [];\n    var text = raw\n      .replace(/\\*{1,3}([^\\*]+)\\*{1,3}/g, '$1')\n      .replace(/^#{1,4}\\s*/gm, '')\n      .replace(/【([^】]*)】/g, '$1');\n    var chunks = text.split(/(?=^\\s*[1-9][\\.、．:：\\s])/m);\n    var result = [];\n    chunks.forEach(function(chunk){\n      chunk = chunk.trim();\n      if(!chunk) return;\n      var m = chunk.match(/^([1-9])[\\.、．:：\\s]+([^\\n]{1,60})\\n([\\s\\S]*)/);\n      if(m){\n        var idx  = parseInt(m[1], 10) - 1;\n        var meta = META[idx] || META[META.length - 1];\n        result.push({\n          ico:   meta.ico,\n          cls:   meta.cls,\n          title: m[2].trim().replace(/[\\.。:：\\s]+$/, ''),\n          body:  m[3].trim()\n        });\n      } else if(result.length === 0 && chunk.length > 10){\n        result.push({ico:'ti-file-text', cls:'c0', title:'分析內容', body:chunk});\n      }\n    });\n    return result;\n  }\n\n  // 只有收到非空 payload 才切換到 done\nscope.$watch('msg.payload', function(val){\n\nif(!val) return;\n\n// =========================\n// payload.result 才是真正 GPT 文字\n// =========================\n\nvar text = '';\n\nif(typeof val === 'object' && val.result){\n\ntext = String(val.result).trim();\n\n} else {\n\ntext = String(val).trim();\n\n}\n\nif(!text) return;\n\nscope.rawText = text;\n\nscope.sections = parse(text);\n\nscope.lastTime =\nnew Date().toLocaleString('zh-TW');\n\nsetState('done');\n\n});\n})(scope);\n</script>",
