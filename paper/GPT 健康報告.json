    {
        "id": "63a3739f1565744c",
        "type": "function",
        "z": "f374f5debb3b6a37",
        "name": "解析GPT結果",
        "func": "let result = '';\n\nif (\nmsg.payload &&\nmsg.payload.choices &&\nmsg.payload.choices[0] &&\nmsg.payload.choices[0].message\n) {\n\n\nresult =\n    msg.payload.choices[0].message.content;\n\n\n}\n\n// =======================\n// token usage\n// =======================\n\nlet usage =\nmsg.payload.usage || {};\n\nlet prompt_tokens =\nusage.prompt_tokens || 0;\n\nlet completion_tokens =\nusage.completion_tokens || 0;\n\nlet total_tokens =\nusage.total_tokens || 0;\n\n// =======================\n// log\n// =======================\n\nnode.warn({\n\n\nprompt_tokens,\n\ncompletion_tokens,\n\ntotal_tokens\n\n\n});\n\n// =======================\n// 成本估算（GPT-4.1-mini）\n// =======================\n\nlet inputCost =\nprompt_tokens * 0.4 / 1000000;\n\nlet outputCost =\ncompletion_tokens * 1.6 / 1000000;\n\nlet totalCost =\ninputCost + outputCost;\n\nnode.warn({\n\n\nusd_cost:\n    totalCost.toFixed(6)\n\n\n});\n\n// =======================\n// payload\n// =======================\n\nmsg.payload = {\n\nresult,\n\nusage: {\n\n    prompt_tokens,\n\n    completion_tokens,\n\n    total_tokens,\n\n    usd_cost:\n        totalCost.toFixed(6)\n}\n\n\n};\n\n// =======================\n// Messenger\n// =======================\n\nlet requester =\nflow.get('health_requester');\n\nif (requester) {\n\nflow.set(\n    'health_requester',\n    null\n);\n\nlet text =\n    result.length > 1900\n    ? result.substring(0,1900)\n      + '\\n\\n⋯（完整報告請查看 Dashboard）'\n    : result;\n\nlet token =\n    global.get('FB_TOKEN');\n\nlet fbMsg =\n    RED.util.cloneMessage(msg);\n\nfbMsg.headers = {\n    'Content-Type':\n        'application/json'\n};\n\nfbMsg.url =\n    'https://graph.facebook.com/v23.0/me/messages?access_token='\n    + token;\n\nfbMsg.payload = {\n\n    recipient: {\n        id: requester\n    },\n\n    message: {\n\n        text:\n            '🐱 貓咪健康分析完成！\\n\\n'\n            + text\n    }\n};\n\nnode.send([msg, fbMsg]);\n\nreturn null;\n\n\n}\n\nreturn [msg, null];\n",
